{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "gcc编译总图项目",
            "type": "shell",
            "command": "gcc",
            "args": [
                "main.c",
                "graph.c",
                "-o",
                "main.exe"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": "$gcc"
        },
        {
            "type": "cppbuild",
            "label": "C/C++: x86_64-6.3.0-release-win32-seh-rt_v5-rev2.7z 生成活动文件",
            "command": "d:\\x86_64-6.3.0-release-win32-seh-rt_v5-rev2.7z",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "d:\\"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "调试器生成的任务。"
        }
    ]
}